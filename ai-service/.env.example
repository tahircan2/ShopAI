# ShopAI AI Service — Environment Variables
# Bu dosyayı .env olarak kopyala ve değerleri doldur.
# .env dosyasını ASLA git'e commit etme — .gitignore'a ekle.

# -------------------------------------------------------
# ZORUNLU — Bu değerler olmadan servis başlamaz
# -------------------------------------------------------

# OpenAI API Anahtarı — YALNIZCA burada saklanır, Angular'a asla taşınmaz
OPENAI_API_KEY=sk-your-openai-api-key-here

# Spring Boot iç servis kimlik doğrulama anahtarı
SPRING_BOOT_INTERNAL_KEY=your-strong-internal-secret-here

# -------------------------------------------------------
# OPSİYONEL — Varsayılan değerler config.py'de tanımlı
# -------------------------------------------------------

OPENAI_MODEL=gpt-4o
SPRING_BOOT_BASE_URL=http://localhost:8080/api
MAX_MESSAGES_PER_SESSION_PER_MINUTE=10
CONVERSATION_HISTORY_LIMIT=10
LOG_LEVEL=INFO
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false
MAX_MESSAGE_LENGTH=500
LANGGRAPH_RECURSION_LIMIT=10
